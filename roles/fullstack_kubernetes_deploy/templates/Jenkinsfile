
pipeline {
agent any

environment {
    PUBLIC_IP = "{{ public_ip }}"
}

stages {

    stage('Clone Kubernetes Repo') {
        steps {
            git branch: 'main', url: 'https://github.com/lavatech321/Kubernetes_CICD_Pipeline.git'
        }
    }

    stage('Update Deployment YAML') {
        steps {
            sh '''
            sed -i "s/REPLACE-IP/${PUBLIC_IP}/g" deployment/todo-app-deploy.yaml
            '''
        }
    }

    stage('Deploy to Minikube') {
        steps {
            sh '''
            sudo -u ubuntu kubectl apply -f deployment/todo-app-deploy.yaml
            '''
        }
    }

    stage('Wait for Deployment') {
        steps {
            sh 'sleep 30'
        }
    }

    stage('Verify Deployment') {
        steps {
            sh '''
            sudo -u ubuntu kubectl get pods
            sudo -u ubuntu kubectl get svc
            '''
        }
    }
}

}

